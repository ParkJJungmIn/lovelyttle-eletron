{
  "name": "lovely-little-eletron",
  "version": "0.1.0",
  "private": true,
  "description": "NanoBanana image generation factory (personal local app).",
  "main": "out/main/index.js",
  "scripts": {
    "postinstall": "electron-rebuild -w better-sqlite3",
    "dev": "electron-rebuild -w better-sqlite3 --silent && electron-vite dev",
    "build": "electron-rebuild -w better-sqlite3 --silent && electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-rebuild -w better-sqlite3 --silent && electron-vite build && electron-builder",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "test": "npm rebuild better-sqlite3 --silent && vitest run",
    "test:watch": "npm rebuild better-sqlite3 --silent && vitest",
    "package:win": "electron-vite build && electron-builder --win --x64",
    "package:mac": "electron-vite build && electron-builder --mac"
  },
  "build": {
    "appId": "dev.jeongmin.nanobanana-factory",
    "productName": "NanoBanana Factory",
    "directories": { "output": "release" },
    "files": ["out/**/*", "package.json"],
    "extraResources": [
      { "from": "src/main/db/migrations", "to": "migrations" }
    ],
    "asarUnpack": ["**/node_modules/better-sqlite3/**"],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "artifactName": "${productName}-${version}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "mac": {
      "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }],
      "category": "public.app-category.graphics-design"
    }
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "better-sqlite3": "^11.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/better-sqlite3": "^7.6.11",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "electron-vite": "^2.3.0",
    "jsdom": "^25.0.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
